<Window x:Class="NutritionOptimizer.UI.Views.FoodDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="음식 상세 정보"
        Height="700"
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 헤더: 음식 이름 -->
        <StackPanel Grid.Row="0" Margin="0 0 0 16">
            <TextBlock Text="{Binding Name}" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Margin="0 8 0 0">
                <TextBlock Text="브랜드: " FontWeight="SemiBold" />
                <TextBlock Text="{Binding Brand}" />
                <TextBlock Text="  |  " Margin="8 0" />
                <TextBlock Text="카테고리: " FontWeight="SemiBold" />
                <TextBlock Text="{Binding Category}" />
            </StackPanel>
        </StackPanel>

        <!-- 내용: 스크롤 가능한 영양 정보 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 기본 정보 -->
                <GroupBox Header="기본 정보" Margin="0 0 0 12" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="단위:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WeightUnit}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="총 가격:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalPrice, StringFormat={}{0:N0}원}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="단위당 가격:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UnitPriceDisplay}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="메모:" FontWeight="SemiBold" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Notes}" TextWrapping="Wrap" />
                    </Grid>
                </GroupBox>

                <!-- 주요 영양소 -->
                <GroupBox Header="주요 영양소" Margin="0 0 0 12" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="칼로리:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Kcal, StringFormat={}{0:N0} kcal}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="탄수화물:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CarbsG, StringFormat={}{0:N1} g}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="단백질:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ProteinG, StringFormat={}{0:N1} g}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="지방:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FatG, StringFormat={}{0:N1} g}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="  - 포화지방:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SaturatedFatG, StringFormat={}{0:N1} g}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="  - 트랜스지방:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding TransFatG, StringFormat={}{0:N1} g}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="식이섬유:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding FiberG, StringFormat={}{0:N1} g}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="당류:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SugarG, StringFormat={}{0:N1} g}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="콜레스테롤:" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding CholesterolMg, StringFormat={}{0:N0} mg}" />
                    </Grid>
                </GroupBox>

                <!-- 무기질 -->
                <GroupBox Header="무기질" Margin="0 0 0 12" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="나트륨:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SodiumMg, StringFormat={}{0:N0} mg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="칼슘:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CalciumMg, StringFormat={}{0:N1} mg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="철분:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding IronMg, StringFormat={}{0:N1} mg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="마그네슘:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MagnesiumMg, StringFormat={}{0:N1} mg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="인:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PhosphorusMg, StringFormat={}{0:N1} mg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="칼륨:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding PotassiumMg, StringFormat={}{0:N1} mg}" Margin="0 0 0 8" />
                    </Grid>
                </GroupBox>

                <!-- 비타민 -->
                <GroupBox Header="비타민" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="비타민 A:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding VitaminAUg, StringFormat={}{0:N1} μg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="비타민 C:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VitaminCMg, StringFormat={}{0:N1} mg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="비타민 D:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding VitaminDUg, StringFormat={}{0:N1} μg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="비타민 E:" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding VitaminEMg, StringFormat={}{0:N1} mg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="비타민 B1 (티아민):" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding VitaminB1Mg, StringFormat={}{0:N2} mg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="비타민 B2 (리보플라빈):" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding VitaminB2Mg, StringFormat={}{0:N2} mg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="비타민 B3 (나이아신):" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding VitaminB3Mg, StringFormat={}{0:N1} mg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="비타민 B6 (피리독신):" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding VitaminB6Mg, StringFormat={}{0:N2} mg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="비타민 B9 (엽산):" FontWeight="SemiBold" Margin="0 0 0 8" />
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding VitaminB9Ug, StringFormat={}{0:N1} μg}" Margin="0 0 0 8" />

                        <TextBlock Grid.Row="9" Grid.Column="0" Text="비타민 B12 (코발라민):" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding VitaminB12Ug, StringFormat={}{0:N2} μg}" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- 하단: 닫기 버튼 -->
        <Button Grid.Row="2"
                Content="닫기"
                Width="100"
                Height="35"
                HorizontalAlignment="Right"
                Margin="0 16 0 0"
                Click="CloseButton_Click" />
    </Grid>
</Window>
