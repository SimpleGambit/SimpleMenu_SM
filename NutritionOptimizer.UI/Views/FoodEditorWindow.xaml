<Window x:Class="NutritionOptimizer.UI.Views.FoodEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="음식 추가/수정"
        Height="750"
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <TextBlock Grid.Row="0"
                   Text="음식 정보 입력"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0 0 0 16" />

        <!-- 입력 폼 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 템플릿 선택 -->
                <GroupBox Header="템플릿 선택 (100g 기준)" Margin="0 0 0 12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="🔍 템플릿 검색" FontWeight="SemiBold" Margin="0 0 0 4" />
                        <TextBox x:Name="TemplateSearchBox" 
                                 TextChanged="TemplateSearchBox_TextChanged"
                                 Margin="0 0 0 8" />
                        
                        <ListBox x:Name="TemplateListBox"
                                 ItemsSource="{Binding Templates}"
                                 SelectedItem="{Binding SelectedTemplate}"
                                 Height="120"
                                 SelectionMode="Single">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Width="150" />
                                        <TextBlock Text=" - " Margin="4 0" />
                                        <TextBlock Text="{Binding Category}" Foreground="Gray" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <TextBlock Text="💡 템플릿을 선택하면 100g 기준 영양성분이 자동으로 입력됩니다" 
                                   Foreground="Gray" 
                                   FontSize="11" 
                                   Margin="0 4 0 0" />
                    </StackPanel>
                </GroupBox>

                <!-- 기본 정보 -->
                <GroupBox Header="기본 정보" Margin="0 0 0 12" Padding="12">
                    <StackPanel>
                        <!-- ID -->
                        <TextBlock Text="ID" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Id}"
                                 IsReadOnly="True"
                                 Background="#F5F5F5"
                                 Margin="0 4 0 12" />

                        <!-- 이름 -->
                        <TextBlock Text="이름 *" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0 4 0 12" />

                        <!-- 브랜드 -->
                        <TextBlock Text="브랜드" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Brand, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0 4 0 12" />

                        <!-- 카테고리 -->
                        <TextBlock Text="카테고리" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0 4 0 12" />

                        <!-- 단위 -->
                        <TextBlock Text="단위(g) * (예: 100g, 700g, 1kg)" FontWeight="SemiBold" />
                        <TextBox Text="{Binding WeightUnit, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0 4 0 12" />

                        <!-- 가격 -->
                        <TextBlock Text="100g당 가격(원)" FontWeight="SemiBold" />
                        <TextBox Text="{Binding PricePer100g, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0 4 0 12" />

                        <!-- 메모 -->
                        <TextBlock Text="메모 (요리법, 제철 정보 등)" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Height="60"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0 4 0 0" />
                    </StackPanel>
                </GroupBox>

                <!-- 영양성분 (읽기 전용) -->
                <TextBlock Text="💡 영양성분은 템플릿과 단위를 기준으로 자동 계산됩니다" 
                           Foreground="Gray" 
                           FontSize="12" 
                           Margin="0 0 0 8" />

                <!-- 주요 영양소 -->
                <GroupBox Header="주요 영양소 (자동 계산)" Margin="0 0 0 12" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 칼로리 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="열량(kcal)" FontWeight="SemiBold" Margin="0 0 8 4" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Kcal}" IsReadOnly="True" Background="#F5F5F5" Margin="0 0 0 8" />

                        <!-- 단백질 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="단백질(g)" FontWeight="SemiBold" Margin="0 0 8 4" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ProteinG}" IsReadOnly="True" Background="#F5F5F5" Margin="0 0 0 8" />

                        <!-- 지방 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="지방(g)" FontWeight="SemiBold" Margin="0 0 8 4" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FatG}" IsReadOnly="True" Background="#F5F5F5" Margin="0 0 0 8" />

                        <!-- 포화지방 -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="포화지방(g)" FontWeight="SemiBold" Margin="0 0 8 4" />
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SaturatedFatG}" IsReadOnly="True" Background="#F5F5F5" Margin="0 0 0 8" />

                        <!-- 트랜스지방 -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="트랜스지방(g)" FontWeight="SemiBold" Margin="0 0 8 4" />
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding TransFatG}" IsReadOnly="True" Background="#F5F5F5" Margin="0 0 0 8" />

                        <!-- 탄수화물 -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="탄수화물(g)" FontWeight="SemiBold" Margin="0 0 8 4" />
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding CarbsG}" IsReadOnly="True" Background="#F5F5F5" Margin="0 0 0 8" />

                        <!-- 식이섬유 -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="식이섬유(g)" FontWeight="SemiBold" Margin="0 0 8 4" />
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding FiberG}" IsReadOnly="True" Background="#F5F5F5" Margin="0 0 0 8" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="기타 영양소 (자동 계산)" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 당류 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="당류(g)" FontWeight="SemiBold" Margin="0 0 8 4" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SugarG}" IsReadOnly="True" Background="#F5F5F5" Margin="0 0 0 8" />

                        <!-- 나트륨 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="나트륨(mg)" FontWeight="SemiBold" Margin="0 0 8 4" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SodiumMg}" IsReadOnly="True" Background="#F5F5F5" Margin="0 0 0 8" />

                        <!-- 콜레스테롤 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="콜레스테롤(mg)" FontWeight="SemiBold" Margin="0 0 8 4" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CholesterolMg}" IsReadOnly="True" Background="#F5F5F5" Margin="0 0 0 8" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- 버튼 -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 16 0 0">
            <Button Content="저장"
                    Width="80"
                    Height="32"
                    Margin="0 0 8 0"
                    Click="SaveButton_Click" />
            <Button Content="취소"
                    Width="80"
                    Height="32"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
