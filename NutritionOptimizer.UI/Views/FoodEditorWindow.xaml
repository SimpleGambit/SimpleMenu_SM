<Window x:Class="NutritionOptimizer.UI.Views.FoodEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="음식 편집"
        Height="700"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <TextBlock Grid.Row="0"
                   Text="{Binding IsEditMode, Converter={StaticResource EditModeTitleConverter}}"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0 0 0 16" />

        <!-- 입력 폼 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- ID -->
                <TextBlock Text="ID" FontWeight="SemiBold" />
                <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="{Binding IsEditMode}"
                         Margin="0 4 0 12" />

                <!-- 이름 -->
                <TextBlock Text="이름 *" FontWeight="SemiBold" />
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 브랜드 -->
                <TextBlock Text="브랜드" FontWeight="SemiBold" />
                <TextBox Text="{Binding Brand, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 카테고리 -->
                <TextBlock Text="카테고리" FontWeight="SemiBold" />
                <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 가격 -->
                <TextBlock Text="가격(₩/100g) *" FontWeight="SemiBold" />
                <TextBox Text="{Binding PricePer100g, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 단위 -->
                <TextBlock Text="단위 *" FontWeight="SemiBold" />
                <TextBox Text="{Binding WeightUnit, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 칼로리 -->
                <TextBlock Text="칼로리(kcal)" FontWeight="SemiBold" />
                <TextBox Text="{Binding Kcal, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 단백질 -->
                <TextBlock Text="단백질(g)" FontWeight="SemiBold" />
                <TextBox Text="{Binding ProteinG, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 지방 -->
                <TextBlock Text="지방(g)" FontWeight="SemiBold" />
                <TextBox Text="{Binding FatG, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 포화지방 -->
                <TextBlock Text="포화지방(g)" FontWeight="SemiBold" />
                <TextBox Text="{Binding SaturatedFatG, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 트랜스지방 -->
                <TextBlock Text="트랜스지방(g)" FontWeight="SemiBold" />
                <TextBox Text="{Binding TransFatG, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 탄수화물 -->
                <TextBlock Text="탄수화물(g)" FontWeight="SemiBold" />
                <TextBox Text="{Binding CarbsG, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 식이섬유 -->
                <TextBlock Text="식이섬유(g)" FontWeight="SemiBold" />
                <TextBox Text="{Binding FiberG, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 당류 -->
                <TextBlock Text="당류(g)" FontWeight="SemiBold" />
                <TextBox Text="{Binding SugarG, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 나트륨 -->
                <TextBlock Text="나트륨(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding SodiumMg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 콜레스테롤 -->
                <TextBlock Text="콜레스테롤(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding CholesterolMg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 무기질 섹션 -->
                <Separator Margin="0 12 0 16" />
                <TextBlock Text="무기질" FontWeight="Bold" FontSize="15" Margin="0 0 0 12" />

                <!-- 칼슘 -->
                <TextBlock Text="칼슘(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding CalciumMg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 철 -->
                <TextBlock Text="철분(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding IronMg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 마그네슘 -->
                <TextBlock Text="마그네슘(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding MagnesiumMg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 인 -->
                <TextBlock Text="인(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding PhosphorusMg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 칼륨 -->
                <TextBlock Text="칼륨(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding PotassiumMg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 아연 -->
                <TextBlock Text="아연(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding ZincMg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 비타민 섹션 -->
                <Separator Margin="0 12 0 16" />
                <TextBlock Text="비타민" FontWeight="Bold" FontSize="15" Margin="0 0 0 12" />

                <!-- 비타민 A -->
                <TextBlock Text="비타민 A(μg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding VitaminAUg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 비타민 C -->
                <TextBlock Text="비타민 C(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding VitaminCMg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 비타민 D -->
                <TextBlock Text="비타민 D(μg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding VitaminDUg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 비타민 E -->
                <TextBlock Text="비타민 E(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding VitaminEMg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 비타민 B1 -->
                <TextBlock Text="비타민 B1/티아민(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding VitaminB1Mg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 비타민 B2 -->
                <TextBlock Text="비타민 B2/리보플라빈(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding VitaminB2Mg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 비타민 B3 -->
                <TextBlock Text="비타민 B3/나이아신(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding VitaminB3Mg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 비타민 B6 -->
                <TextBlock Text="비타민 B6/피리독신(mg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding VitaminB6Mg, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 비타민 B9 -->
                <TextBlock Text="비타민 B9/엽산(μg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding VitaminB9Ug, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />

                <!-- 비타민 B12 -->
                <TextBlock Text="비타민 B12/코발라민(μg)" FontWeight="SemiBold" />
                <TextBox Text="{Binding VitaminB12Ug, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 4 0 12" />
            </StackPanel>
        </ScrollViewer>

        <!-- 버튼 -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 16 0 0">
            <Button Content="저장"
                    Width="80"
                    Height="32"
                    Margin="0 0 8 0"
                    Click="SaveButton_Click" />
            <Button Content="취소"
                    Width="80"
                    Height="32"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
